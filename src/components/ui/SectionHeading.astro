---
type Props = {
  title: string;
  subtitle?: string;
  eyebrow?: string;
  align?: "center" | "left";
  light?: boolean;
  as?: "h2" | "h1";
};

const { title, subtitle, eyebrow, align = "center", light = false, as: Tag = "h2" } = Astro.props;
---

<div class:list={["flex flex-col gap-4", align === "center" ? "items-center text-center" : "items-start text-left"]}>
  {eyebrow && (
    <span class:list={["font-display text-sm font-bold uppercase tracking-[0.2em]", light ? "text-brand-green-400" : "text-brand-green-600"]}>
      {eyebrow}
    </span>
  )}
  <div class:list={["flex w-screen items-center gap-4 sm:gap-6", align === "center" ? "justify-center" : "justify-start"]} style="margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw);">
    <span
      class:list={["hidden flex-1 sm:flex flex-col gap-2", align === "left" && "max-w-16"]}
      aria-hidden="true"
    >
      <span class:list={["h-[11px] w-full", light ? "bg-white/70" : "bg-navy-800"]}></span>
      <span class="h-[11px] w-full bg-brand-green-500"></span>
    </span>
    <Tag class:list={["min-w-0 shrink text-balance font-heading text-[34px] font-bold sm:text-[46px] lg:text-[50px] lg:leading-[62px]", light ? "text-white" : "text-navy-800"]}>
      {title}
    </Tag>
    <span class:list={["hidden flex-1 sm:flex flex-col gap-2", align === "left" && "invisible"]} aria-hidden="true">
      <span class:list={["h-[11px] w-full", light ? "bg-white/70" : "bg-navy-800"]}></span>
      <span class="h-[11px] w-full bg-brand-green-500"></span>
    </span>
  </div>
  {subtitle && (
    <p class:list={["max-w-2xl text-base leading-relaxed sm:text-lg", light ? "text-white/80" : "text-navy-600"]}>
      {subtitle}
    </p>
  )}
</div>
