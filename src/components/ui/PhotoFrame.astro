---
// Stylized placeholder for brand photography slots.
// Swap the <slot> content or wrap a real <Image> here once client photo assets are supplied.
type Props = {
  class?: string;
  tone?: "navy" | "green";
  label?: string;
};

const { class: className = "", tone = "navy", label = "Photo placeholder" } = Astro.props;

const tones = {
  navy: "from-navy-700 via-navy-800 to-navy-900",
  green: "from-brand-green-600 via-navy-800 to-navy-900",
};
---

<div class:list={["relative isolate flex items-center justify-center overflow-hidden bg-gradient-to-br", tones[tone], className]}>
  <svg
    class="absolute inset-0 h-full w-full opacity-20"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <pattern id="grid" width="28" height="28" patternUnits="userSpaceOnUse">
        <path d="M28 0H0V28" fill="none" stroke="white" stroke-width="0.5" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#grid)" />
  </svg>
  <div class="relative flex flex-col items-center gap-3 text-white/70">
    <slot>
      <svg viewBox="0 0 64 64" class="h-16 w-16" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <rect x="6" y="24" width="34" height="20" rx="3" />
        <path d="M40 30h10l8 8v6H40z" />
        <circle cx="18" cy="46" r="5" />
        <circle cx="48" cy="46" r="5" />
      </svg>
      <span class="text-xs font-semibold uppercase tracking-widest">{label}</span>
    </slot>
  </div>
</div>
