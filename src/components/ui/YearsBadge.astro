---
// Two-sided "sandwich" of the legacy trust badge, spun continuously on the Y axis.
// The back face's own 180deg rotation cancels out with the container's animated
// rotation once it swings past 180deg, so it reads correctly instead of mirrored.
type Props = {
  years: number;
  year: number;
  class?: string;
};

const { years, year, class: className = "" } = Astro.props;
const badgeSrc = "/NEW/Legacy%20Trust%20Badge.webp";
---

<div class:list={["legacy-badge-perspective", className]}>
  <div class="legacy-badge-spin">
    <img
      src={badgeSrc}
      alt={`${years} years in business, established ${year}`}
      class="legacy-badge-face legacy-badge-front"
      draggable="false"
    />
    <img src={badgeSrc} alt="" aria-hidden="true" class="legacy-badge-face legacy-badge-back" draggable="false" />
  </div>
</div>

<style>
  .legacy-badge-perspective {
    perspective: 900px;
  }

  .legacy-badge-spin {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    animation: legacy-badge-rotate 9s linear infinite;
  }

  .legacy-badge-face {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    backface-visibility: hidden;
  }

  .legacy-badge-back {
    transform: rotateY(180deg);
  }

  @keyframes legacy-badge-rotate {
    from {
      transform: rotateY(0deg);
    }
    to {
      transform: rotateY(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .legacy-badge-spin {
      animation: none;
    }
  }
</style>
