---
import { Image } from "astro:assets";
import legacyPhoto from "@assets/photos/legacy-crew-truck.webp";
import { business } from "@data/site";
import LegacyScrollText from "./LegacyScrollText";
---

<section class="relative overflow-hidden">
  <Image
    src={legacyPhoto}
    alt="A Jim Dandy technician standing in front of a company service van outside a customer's home"
    width={2160}
    height={793}
    loading="lazy"
    class="relative aspect-[1440/657] w-full object-cover object-top"
  />
  <div class="flex items-center overflow-hidden bg-navy-800 py-8 sm:py-10">
    <h2 class="sr-only">{business.yearsInBusiness} Years Of Legacy</h2>
    <div class="w-full leading-none" aria-hidden="true">
      <LegacyScrollText client:visible text={`${business.yearsInBusiness} Years Of Legacy`} />
    </div>
  </div>
</section>
