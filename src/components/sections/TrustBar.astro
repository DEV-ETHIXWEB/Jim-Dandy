---
import { Image } from "astro:assets";
import SectionHeading from "@components/ui/SectionHeading.astro";
import { business } from "@data/site";
import bbbLogo from "@assets/logos/bbb.webp";
import angiLogo from "@assets/logos/angi.webp";
import phccLogo from "@assets/logos/phcc.webp";

const logoBadges = [
  { label: "BBB Accredited Business", logo: bbbLogo },
  { label: "Angi Super Service Award 2024", logo: angiLogo },
  { label: "PHCC Certified Member", logo: phccLogo },
  { label: "BBB Accredited Business", logo: bbbLogo },
];

// Repeated 3x for a seamless, long-feeling loop from just 4 logos.
const marqueeLogos = [...logoBadges, ...logoBadges, ...logoBadges];
---

<section class="relative overflow-hidden py-20 lg:py-28">
  <div class="container-page relative flex flex-col items-center gap-10">
    <SectionHeading title="Licensed & Insured" subtitle="Your home is in good hands." />

    <div class="flex flex-col items-center gap-5">
      <span class="font-display text-3xl font-bold uppercase text-navy-800 sm:text-4xl">
        License No.
      </span>
      <div class="flex flex-wrap items-center justify-center gap-4">
        {business.licenses.map((license, i) => (
          <>
            {i > 0 && <span class="h-6 w-px bg-navy-300" aria-hidden="true"></span>}
            <span class="stamp-pill relative rounded-full bg-navy-800 px-7 py-3 font-mono text-base font-semibold tracking-wide text-white">
              {license}
            </span>
          </>
        ))}
      </div>
    </div>

    <div class="trustbar-viewport relative left-1/2 w-screen max-w-[1300px] -translate-x-1/2">
      <div
        class="pointer-events-none absolute inset-y-0 left-0 z-10 w-20 bg-gradient-to-r from-brand-green-50 via-brand-green-50/70 to-transparent backdrop-blur-[3px] sm:w-36"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-y-0 right-0 z-10 w-20 bg-gradient-to-l from-brand-green-50 via-brand-green-50/70 to-transparent backdrop-blur-[3px] sm:w-36"
        aria-hidden="true"
      >
      </div>

      <div class="trustbar-track flex w-max items-center gap-20" aria-hidden="true">
        {marqueeLogos.map(({ label, logo }) => (
          <div class="trustbar-logo shrink-0">
            <Image
              src={logo}
              alt={label}
              height={128}
              loading="lazy"
              class="h-16 w-auto object-contain grayscale"
            />
          </div>
        ))}
      </div>
      <span class="sr-only">BBB Accredited Business, Angi Super Service Award 2024, PHCC Certified Member</span>
    </div>
  </div>
</section>

<style>
  .stamp-pill::before,
  .stamp-pill::after {
    content: "";
    position: absolute;
    left: 12px;
    right: 12px;
    height: 13px;
    background: var(--color-navy-800);
    -webkit-mask-image: radial-gradient(circle at 6.5px 6.5px, black 5.5px, transparent 6px);
    mask-image: radial-gradient(circle at 6.5px 6.5px, black 5.5px, transparent 6px);
    -webkit-mask-size: 13px 13px;
    mask-size: 13px 13px;
    -webkit-mask-repeat: repeat-x;
    mask-repeat: repeat-x;
  }
  .stamp-pill::before {
    top: -6.5px;
  }
  .stamp-pill::after {
    bottom: -6.5px;
  }

  .trustbar-track {
    animation: trustbar-scroll 28s linear infinite;
  }

  .trustbar-viewport:hover .trustbar-track {
    animation-play-state: paused;
  }

  .trustbar-logo {
    transition:
      transform 120ms linear,
      filter 120ms linear;
    will-change: transform, filter;
  }

  @keyframes trustbar-scroll {
    from {
      transform: translateX(-33.3333%);
    }
    to {
      transform: translateX(0%);
    }
  }
</style>

<script>
  function initTrustbarPop(viewport: Element) {
    const items = Array.from(viewport.querySelectorAll<HTMLElement>(".trustbar-logo"));
    if (!items.length) return;

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    let raf = 0;

    function tick() {
      const vRect = viewport.getBoundingClientRect();
      const centerX = vRect.left + vRect.width / 2;
      const falloff = Math.max(vRect.width * 0.16, 90);

      for (const item of items) {
        const r = item.getBoundingClientRect();
        const itemCenter = r.left + r.width / 2;
        const distance = Math.abs(itemCenter - centerX);
        const proximity = Math.max(0, 1 - distance / falloff);
        const scale = 1 + proximity * 0.4;
        const gray = 1 - proximity;
        item.style.transform = `scale(${scale.toFixed(3)})`;
        item.style.filter = `grayscale(${gray.toFixed(3)})`;
      }

      raf = requestAnimationFrame(tick);
    }

    raf = requestAnimationFrame(tick);

    document.addEventListener(
      "visibilitychange",
      () => {
        if (document.hidden) cancelAnimationFrame(raf);
        else raf = requestAnimationFrame(tick);
      },
      { passive: true },
    );
  }

  document.querySelectorAll(".trustbar-viewport").forEach(initTrustbarPop);
</script>
