---
import Layout from "@layouts/Layout.astro";
import ServiceArea from "@components/sections/ServiceArea";
import FinalCta from "@components/sections/FinalCta.astro";
import { business, serviceAreaCities } from "@data/site";
import { breadcrumbSchema } from "@lib/seo";
import { ChevronRight, MapPin } from "lucide-react";

const crumbs = breadcrumbSchema([
  { name: "Home", path: "/" },
  { name: "Service Area", path: "/service-area" },
]);
---

<Layout
  title="Service Area | Jim Dandy Sewer & Plumbing"
  description="Jim Dandy Sewer & Plumbing dispatches licensed technicians same-day across King, Snohomish, and Pierce Counties, including Seattle, Bellevue, Tacoma, and Everett."
  path="/service-area"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(crumbs)} slot="head" />

  <section class="relative overflow-hidden bg-navy-900 py-16 lg:py-20">
    <div
      class="pointer-events-none absolute inset-0 opacity-40"
      style="background: radial-gradient(600px circle at 15% 20%, rgba(105,190,40,0.18), transparent 60%);"
      aria-hidden="true"
    ></div>
    <div class="container-page relative flex flex-col items-start gap-6">
      <nav aria-label="Breadcrumb" class="flex items-center gap-1.5 text-sm text-white/60">
        <a href="/" class="hover:text-white">Home</a>
        <ChevronRight className="h-3.5 w-3.5" aria-hidden="true" />
        <span class="text-white">Service Area</span>
      </nav>
      <h1 class="font-display text-[38px] font-black italic leading-[1.05] text-cloud sm:text-[52px]">
        Proudly Serving the Puget Sound Region
      </h1>
      <p class="max-w-xl text-lg leading-relaxed text-white/80">
        Licensed plumbers dispatched same-day across King, Snohomish, and Pierce Counties.
      </p>
    </div>
  </section>

  <section class="bg-white py-20 lg:py-28">
    <div class="container-page">
      <ServiceArea client:visible />
    </div>
  </section>

  <section class="bg-surface py-20 lg:py-28">
    <div class="container-page flex flex-col gap-14">
      <div class="mx-auto flex max-w-2xl flex-col items-center gap-4 text-center">
        <h2 class="font-heading text-2xl font-bold text-navy-800 sm:text-4xl">Cities We Serve</h2>
        <p class="text-base leading-relaxed text-navy-600 sm:text-lg">
          Same-day dispatch and 24/7 emergency response in every city below.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {serviceAreaCities.map((city) => {
          const slug = city.toLowerCase().replace(/\s+/g, "-");
          return (
            <div id={slug} class="scroll-mt-24 rounded-2xl border border-navy-200 bg-white p-6">
              <div class="flex items-center gap-2.5">
                <MapPin className="h-5 w-5 shrink-0 text-brand-green-600" aria-hidden="true" />
                <h3 class="font-display text-xl font-bold text-navy-800">{city}</h3>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-navy-600">
                Licensed plumbers available same-day in {city} for emergency and scheduled
                plumbing, drain, and sewer service.
              </p>
              <a
                href={business.phoneHref}
                class="mt-3 inline-block text-sm font-semibold text-navy-700 underline hover:text-brand-green-600"
              >
                Call {business.phone}
              </a>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <FinalCta />
</Layout>
