---
import Layout from "@layouts/Layout.astro";
import Button from "@components/ui/Button.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import FinalCta from "@components/sections/FinalCta.astro";
import { business } from "@data/site";
import { coupons } from "@data/coupons";
import { breadcrumbSchema } from "@lib/seo";
import { ChevronRight, Tag } from "lucide-react";

const crumbs = breadcrumbSchema([
  { name: "Home", path: "/" },
  { name: "Coupons", path: "/coupons" },
]);
---

<Layout
  title="Coupons & Specials | Jim Dandy Sewer & Plumbing"
  description="Current plumbing and sewer service coupons from Jim Dandy Sewer & Plumbing - savings on repairs, new customer discounts, and free inspections."
  path="/coupons"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(crumbs)} slot="head" />

  <section class="relative overflow-hidden bg-navy-900 py-16 lg:py-20">
    <div
      class="pointer-events-none absolute inset-0 opacity-40"
      style="background: radial-gradient(600px circle at 15% 20%, rgba(105,190,40,0.18), transparent 60%);"
      aria-hidden="true"
    ></div>
    <div class="container-page relative flex flex-col items-start gap-6">
      <nav aria-label="Breadcrumb" class="flex items-center gap-1.5 text-sm text-white/60">
        <a href="/" class="hover:text-white">Home</a>
        <ChevronRight className="h-3.5 w-3.5" aria-hidden="true" />
        <span class="text-white">Coupons</span>
      </nav>
      <h1 class="font-display text-[38px] font-black italic leading-[1.05] text-cloud sm:text-[52px]">
        Coupons &amp; Specials
      </h1>
      <p class="max-w-xl text-lg leading-relaxed text-white/80">
        Mention any offer below when you call or schedule online. Ask your technician if you
        qualify for more than one.
      </p>
    </div>
  </section>

  <section class="bg-surface py-20 lg:py-28">
    <div class="container-page flex flex-col gap-14">
      <SectionHeading title="Current Offers" subtitle="Valid for service within our Puget Sound coverage area." />
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {coupons.map((coupon) => (
          <div class="flex flex-col gap-4 rounded-[32px] border border-navy-200 bg-white p-8 shadow-card">
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-green-50 text-brand-green-600">
              <Tag className="h-6 w-6" aria-hidden="true" />
            </span>
            <h3 class="font-display text-2xl font-bold leading-tight text-navy-800">{coupon.title}</h3>
            <p class="text-base leading-relaxed text-navy-600">{coupon.description}</p>
            <p class="text-xs leading-relaxed text-navy-400">{coupon.terms}</p>
            <Button href={business.scheduleUrl} variant="ghost" size="md" class="mt-2">
              Redeem This Offer
            </Button>
          </div>
        ))}
      </div>
      <p class="text-center text-sm text-navy-400">
        Offers subject to change without notice. Call {business.phone} to confirm current
        promotions before your appointment.
      </p>
    </div>
  </section>

  <FinalCta />
</Layout>
